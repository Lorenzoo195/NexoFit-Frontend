---
// Toaster component - Global toast notifications (Vanilla JS)
---

<div id="toast-container" class="fixed top-4 right-4 z-9999 flex flex-col gap-2 pointer-events-none max-w-md"></div>

<script>
  interface ToastOptions {
    duration?: number;
    type?: 'success' | 'error' | 'warning' | 'info';
    description?: string;
  }

  class Toast {
    private container: HTMLElement;
    private toastCount = 0;

    constructor() {
      this.container = document.getElementById('toast-container')!;
    }

    private createToast(message: string, options: ToastOptions = {}) {
      const { duration = 4000, type = 'info', description } = options;
      const toastId = `toast-${++this.toastCount}`;

      const icons = {
        success: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>',
        error: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>',
        warning: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>',
        info: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>',
      };

      const colors = {
        success: 'bg-green-600 border-green-500 text-white',
        error: 'bg-red-600 border-red-500 text-white',
        warning: 'bg-orange-600 border-orange-500 text-white',
        info: 'bg-zinc-800 border-zinc-700 text-white',
      };

      const toast = document.createElement('div');
      toast.id = toastId;
      toast.className = `${colors[type]} pointer-events-auto border rounded-lg shadow-2xl p-4 flex items-start gap-3 animate-slide-in-right min-w-[320px] max-w-md`;
      toast.innerHTML = `
        <div class="flex-shrink-0 mt-0.5">${icons[type]}</div>
        <div class="flex-1 min-w-0">
          <p class="font-semibold text-sm">${message}</p>
          ${description ? `<p class="text-xs mt-1 opacity-90">${description}</p>` : ''}
        </div>
        <button class="flex-shrink-0 ml-2 opacity-70 hover:opacity-100 transition-opacity" onclick="this.parentElement.remove()">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      `;

      this.container.appendChild(toast);

      // Auto remove after duration
      setTimeout(() => {
        if (toast.parentElement) {
          toast.classList.add('animate-slide-out-right');
          setTimeout(() => toast.remove(), 300);
        }
      }, duration);

      return toastId;
    }

    success(message: string, options?: Omit<ToastOptions, 'type'>) {
      return this.createToast(message, { ...options, type: 'success' });
    }

    error(message: string, options?: Omit<ToastOptions, 'type'>) {
      return this.createToast(message, { ...options, type: 'error' });
    }

    warning(message: string, options?: Omit<ToastOptions, 'type'>) {
      return this.createToast(message, { ...options, type: 'warning' });
    }

    info(message: string, options?: Omit<ToastOptions, 'type'>) {
      return this.createToast(message, { ...options, type: 'info' });
    }

    message(message: string, options?: ToastOptions) {
      return this.createToast(message, options);
    }
  }

  // Initialize and export globally
  const toaster = new Toast();
  (window as any).toast = toaster;
</script>

<style is:global>
  @keyframes slide-in-right {
    from {
      transform: translateX(100%);
      opacity: 0;
    }
    to {
      transform: translateX(0);
      opacity: 1;
    }
  }

  @keyframes slide-out-right {
    from {
      transform: translateX(0);
      opacity: 1;
    }
    to {
      transform: translateX(100%);
      opacity: 0;
    }
  }

  .animate-slide-in-right {
    animation: slide-in-right 0.3s ease-out;
  }

  .animate-slide-out-right {
    animation: slide-out-right 0.3s ease-in;
  }
</style>
